# Neon (PostgreSQL) — use a connection string "pooled" / serverless do dashboard Neon
# https://neon.tech/docs/connect/connection-string
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Configurações de Email (Gmail)
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=sua_senha_de_app_16_chars

# Suas informações de contato (aparece no email enviado)
COMPANY_NAME=Sua Empresa
CONTACT_EMAIL=contato@suaempresa.com
CONTACT_WHATSAPP=5571999999999
CONTACT_PHONE=(71) 99999-9999

# Servidor
PORT=3000
