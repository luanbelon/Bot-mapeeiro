<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background-color:#0f172a; font-family: 'Segoe UI', Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#0f172a; padding: 20px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#1e293b; border-radius:16px; overflow:hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.3);">

          <!-- Header -->
          <tr>
            <td style="background: linear-gradient(135deg, #6366f1, #8b5cf6, #a855f7); padding: 40px 30px; text-align: center;">
              <h1 style="color:#fff; margin:0; font-size:24px; font-weight:700;">📊 Diagnóstico do Seu Site</h1>
              <p style="color:rgba(255,255,255,0.85); margin:10px 0 0; font-size:14px;">Análise gratuita e personalizada para <strong>{{businessName}}</strong></p>
            </td>
          </tr>

          <!-- Intro -->
          <tr>
            <td style="padding: 30px;">
              <p style="color:#cbd5e1; font-size:15px; line-height:1.6; margin:0;">
                Olá, equipe <strong style="color:#e2e8f0;">{{businessName}}</strong>! 👋
              </p>
              <p style="color:#94a3b8; font-size:14px; line-height:1.6; margin:15px 0 0;">
                Analisamos o site <strong style="color:#818cf8;">{{websiteUrl}}</strong> e preparamos este diagnóstico gratuito com insights importantes para melhorar sua presença digital.
              </p>
            </td>
          </tr>

          <!-- Scores Grid -->
          <tr>
            <td style="padding: 0 30px;">
              <table width="100%" cellpadding="0" cellspacing="8">
                <tr>
                  <td width="50%" style="background-color:#0f172a; border-radius:12px; padding:20px; text-align:center;">
                    <div style="font-size:32px; font-weight:800; color:{{performanceColor}};">{{performanceScore}}</div>
                    <div style="color:#94a3b8; font-size:12px; margin-top:5px;">⚡ PERFORMANCE</div>
                  </td>
                  <td width="50%" style="background-color:#0f172a; border-radius:12px; padding:20px; text-align:center;">
                    <div style="font-size:32px; font-weight:800; color:{{seoColor}};">{{seoScore}}</div>
                    <div style="color:#94a3b8; font-size:12px; margin-top:5px;">🔍 SEO</div>
                  </td>
                </tr>
                <tr>
                  <td width="50%" style="background-color:#0f172a; border-radius:12px; padding:20px; text-align:center;">
                    <div style="font-size:32px; font-weight:800; color:{{accessibilityColor}};">{{accessibilityScore}}</div>
                    <div style="color:#94a3b8; font-size:12px; margin-top:5px;">♿ ACESSIBILIDADE</div>
                  </td>
                  <td width="50%" style="background-color:#0f172a; border-radius:12px; padding:20px; text-align:center;">
                    <div style="font-size:32px; font-weight:800; color:{{bestPracticesColor}};">{{bestPracticesScore}}</div>
                    <div style="color:#94a3b8; font-size:12px; margin-top:5px;">✅ BOAS PRÁTICAS</div>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Extra Info -->
          <tr>
            <td style="padding: 20px 30px;">
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td style="background-color:#0f172a; border-radius:10px; padding:14px 18px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="color:#94a3b8; font-size:13px;">🔒 SSL (HTTPS)</td>
                        <td align="right" style="font-size:13px; color:{{#if hasSSL}}#22c55e{{else}}#ef4444{{/if}}; font-weight:600;">
                          {{#if hasSSL}}Ativo ✅{{else}}Inativo ❌{{/if}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr><td style="height:8px;"></td></tr>
                <tr>
                  <td style="background-color:#0f172a; border-radius:10px; padding:14px 18px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="color:#94a3b8; font-size:13px;">📱 Responsivo (Mobile)</td>
                        <td align="right" style="font-size:13px; color:{{#if isResponsive}}#22c55e{{else}}#ef4444{{/if}}; font-weight:600;">
                          {{#if isResponsive}}Sim ✅{{else}}Não ❌{{/if}}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr><td style="height:8px;"></td></tr>
                <tr>
                  <td style="background-color:#0f172a; border-radius:10px; padding:14px 18px;">
                    <table width="100%" cellpadding="0" cellspacing="0">
                      <tr>
                        <td style="color:#94a3b8; font-size:13px;">⏱️ Tempo de Carregamento</td>
                        <td align="right" style="font-size:13px; color:#e2e8f0; font-weight:600;">
                          {{loadTime}}s
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Suggestions -->
          {{#if suggestions}}
          <tr>
            <td style="padding: 10px 30px 20px;">
              <h3 style="color:#e2e8f0; font-size:16px; margin:0 0 15px;">📋 Melhorias Sugeridas</h3>
              {{#each suggestions}}
              <div style="background-color:#0f172a; border-radius:10px; padding:16px 18px; margin-bottom:10px; border-left: 3px solid {{#if (eq type 'critical')}}#ef4444{{else if (eq type 'warning')}}#f59e0b{{else if (eq type 'tip')}}#3b82f6{{else}}#22c55e{{/if}};">
                <div style="color:#e2e8f0; font-size:14px; font-weight:600; margin-bottom:6px;">{{title}}</div>
                <div style="color:#94a3b8; font-size:13px; line-height:1.5;">{{description}}</div>
              </div>
              {{/each}}
            </td>
          </tr>
          {{/if}}

          <!-- CTA -->
          <tr>
            <td style="padding: 10px 30px 30px;">
              <div style="background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius:14px; padding:30px; text-align:center;">
                <h3 style="color:#fff; margin:0 0 10px; font-size:18px;">🚀 Quer melhorar seu site?</h3>
                <p style="color:rgba(255,255,255,0.85); font-size:14px; margin:0 0 20px; line-height:1.5;">
                  Nossa equipe pode implementar todas essas melhorias para você.<br>Entre em contato para uma consultoria gratuita!
                </p>
                {{#if contactWhatsapp}}
                <a href="https://wa.me/{{contactWhatsapp}}?text=Olá! Vi o diagnóstico do meu site e gostaria de saber mais sobre os serviços de vocês." style="display:inline-block; background-color:#22c55e; color:#fff; text-decoration:none; padding:14px 32px; border-radius:10px; font-weight:700; font-size:15px;">💬 Falar no WhatsApp</a>
                {{/if}}
                {{#if contactEmail}}
                <p style="color:rgba(255,255,255,0.7); font-size:13px; margin:15px 0 0;">
                  📧 Ou envie um email para: <a href="mailto:{{contactEmail}}" style="color:#c4b5fd;">{{contactEmail}}</a>
                </p>
                {{/if}}
                {{#if contactPhone}}
                <p style="color:rgba(255,255,255,0.7); font-size:13px; margin:8px 0 0;">
                  📞 Ligue: {{contactPhone}}
                </p>
                {{/if}}
              </div>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding: 20px 30px; border-top: 1px solid #334155; text-align:center;">
              <p style="color:#64748b; font-size:11px; margin:0; line-height:1.6;">
                Este diagnóstico foi gerado automaticamente por <strong>{{companyName}}</strong>.<br>
                Se não deseja receber mais emails como este,
                <a href="mailto:{{contactEmail}}?subject=Descadastrar&body=Por favor, remova meu email da lista." style="color:#818cf8;">clique aqui para se descadastrar</a>.
              </p>
              <p style="color:#475569; font-size:10px; margin:10px 0 0;">© {{year}} {{companyName}}. Todos os direitos reservados.</p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>
